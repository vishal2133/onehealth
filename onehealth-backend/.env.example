ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/onehealth
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
OTP_EXPIRE_MINUTES=10
DEV_OTP_CODE=123456
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional Gmail SMTP. Without these, OTPs print to the API console.
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
